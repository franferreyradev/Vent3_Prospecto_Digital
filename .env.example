# === DATABASE ===
DATABASE_URL=postgresql+asyncpg://vent3:vent3dev@localhost:5432/vent3_db

# === SEGURIDAD ===
SECRET_KEY=cambia-esto-por-un-secret-de-64-chars-minimo
INTERNAL_API_TOKEN=token-compartido-entre-nextjs-y-fastapi

# === ADMIN INICIAL ===
ADMIN_EMAIL=admin@vent3.com.ar
ADMIN_INITIAL_PASSWORD=cambia-esto-en-produccion

# === FRONTEND ===
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# === CLOUDFLARE R2 ===
R2_ACCOUNT_ID=tu-account-id
R2_ACCESS_KEY_ID=tu-access-key
R2_SECRET_ACCESS_KEY=tu-secret-key
R2_BUCKET_NAME=vent3-prospectos
R2_PUBLIC_URL=https://tu-bucket.r2.dev

# LOCAL: postgresql+asyncpg://vent3:vent3dev@localhost:5433/vent3_db
# RAILWAY: lo provee Railway automáticamente como variable DATABASE_URL

# R2_PUBLIC_URL: URL pública del bucket (habilitar public access en el panel R2)
# Formato: https://[hash].r2.dev o dominio custom si se configura

# === NEXT.JS (solo apps/web) ===
NEXT_PUBLIC_API_URL=https://api.vent3.com.ar
# LOCAL: http://localhost:8000